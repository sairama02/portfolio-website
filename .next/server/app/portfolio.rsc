4:["$","$L10",null,{"projects":[{"id":"5d3b9641-6531-4c6c-9b8c-604ee49e1c5f","title":"AskSai","headline":"AI Onboarding Knowledge Graph Assistant","description":"AI-powered onboarding assistant that transforms internal training guides into structured knowledge graphs for context-aware support.","details":"Designed an AI-powered assistant that converts internal training guides into structured knowledge graphs to enable context-aware support\nImplemented an LLM-based document ingestion pipeline to extract entities, relationships, and workflows for structured knowledge graphs\nBuilt embedding-based semantic search to map user queries to relevant knowledge graph nodes and supporting documents\nDefined evaluation metrics to measure answer relevance and retrieval accuracy across common onboarding scenarios","tech_stack":["Python","LLM APIs","Retrieval Pipelines","Knowledge Graph Modeling"],"live_url":null,"github_url":null,"display_order":1,"image_url":null},{"id":"5c4571c4-3688-4b10-9700-cf184d3aa27a","title":"TruthDose","headline":"AI-Powered Health Claim Verification Chrome Extension","description":"Chrome extension that evaluates online health claims by retrieving peer-reviewed research and ranking evidence with an interpretable truth score.","details":"Built a Chrome extension that evaluates online health claims by retrieving peer-reviewed research via PubMed and Semantic Scholar APIs\nCreated a hybrid ranking algorithm combining citation influence and publication recency to compute an interpretable Truth Score from 0 to 100 percent\nDesigned a retrieval-based pipeline to surface relevant research papers and rank them based on contextual relevance and impact metrics","tech_stack":["JavaScript","Python","PubMed API","Semantic Scholar API"],"live_url":null,"github_url":null,"display_order":2,"image_url":null},{"id":"21913180-a8d4-4e34-a284-b86a78aebcc1","title":"PolyPlannerPro","headline":"Full-Stack Academic Planning Web Application","description":"Full-stack academic planning platform built for student and faculty workflows, with responsive UI, RBAC, testing, and technical documentation.","details":"Designed and implemented responsive React interfaces enabling students and faculty to manage academic planning workflows\nBuilt secure role-based access control across REST API endpoints to support multi-user identity scenarios\nImplemented unit tests to validate core UI logic and ensure reliability of user workflows\nAuthored comprehensive technical documentation to enable long-term maintainability and onboarding of future student developers\nCollaborated with a new development team to ensure smooth project handoff and continued iteration after initial deployment","tech_stack":["TypeScript","React.js","Java","Figma","Node.js","Jakarta Persistence"],"live_url":"https://www.polyplanner.pro/","github_url":null,"display_order":3,"image_url":null},{"id":"a681b78f-b24f-4905-9e5c-cc39f87a20e2","title":"Uniform Information Hub Database - Global Emancipation Network (GEN)","headline":"Relational Database Design for Multi-Location Operational Data","description":"Designed and deployed a relational database to support structured operational data across multiple organizational locations, focusing on normalized schema design, data integrity, and maintainable data relationships.","details":"Designed relational database schema to manage structured operational data across multiple organizational locations\nModeled entities, relationships, and constraints using ER diagrams and normalized schemas to ensure data integrity and reduce redundancy\nIteratively refined schema design based on evolving stakeholder requirements, balancing flexibility with maintainability\nDeployed database to AWS EC2 and validated schema consistency through SQL testing and debugging\n  Ensured reliable data representation through primary/foreign key relationships and constraint enforcement","tech_stack":["MySQL","AWS EC2","Data Modeling"],"live_url":null,"github_url":null,"display_order":4,"image_url":null}],"experiences":[{"id":"15746c2b-44d5-408f-b728-05244af04fe4","company":"Gamified Machine Embroidery","role":"Undergraduate Researcher","location":"San Luis Obispo, CA","description":"Built a collaborative two-player drawing interface using JavaScript and Paper.js to simplify embroidery design workflows\n    Engineered custom brush tools and optimized stitch-density post-processing for physical machine compatibility\n    Developed an expressive NPC system that dynamically responded to user design input","start_date":"$D2024-06-15T07:00:00.000Z","end_date":"$D2024-10-20T07:00:00.000Z"},{"id":"96f23993-ac20-45df-9ec0-d1cd6df3ab38","company":"AI for Search and Rescue","role":"Undergraduate Researcher","location":"San Luis Obispo, CA","description":"Led development of a real-time React dashboard for Search and Rescue operations, integrating Firebase for live incident data synchronization\n    Implemented automated form prefill logic using React hooks to reduce human data-entry errors\n    Designed intuitive data visualizations to improve usability and support faster operational decision-making in field scenarios","start_date":"$D2023-05-10T07:00:00.000Z","end_date":"$D2023-12-16T08:00:00.000Z"},{"id":"c9faefed-95b9-4001-aeb8-c3d0188a1d14","company":"Avisys Services WLL @ Saudi Telecom Company","role":"Web Software Development Intern","location":"Manama, Bahrain","description":"Developed interactive web-based games in JavaScript to increase customer engagement\n    Built and updated Drupal/PHP web components based on client specifications\n    Designed a high-fidelity mobile app prototype in React Native to improve user experience","start_date":"$D2022-11-01T07:00:00.000Z","end_date":"$D2022-12-25T08:00:00.000Z"}]}]
